# ── OCR engines ───────────────────────────────────────────────────────────────
# Primary: Tesseract (must be installed on system)
# Secondary: EasyOCR (auto-installed via requirements.txt)
# Fallback: Google Cloud Vision (set key below)

GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── API ───────────────────────────────────────────────────────────────────────
# Optional: OpenAI / Anthropic for summary refinement
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
MAX_FILE_SIZE_MB=50
